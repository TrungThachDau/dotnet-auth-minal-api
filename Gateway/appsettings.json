{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
  "route1": {
    "RouteId": "route1",
    "ClusterId": "clusterA",
    "Match": { "Path": "/auth/{**catch-all}" }
  },
  "route2": {
    "RouteId": "route2",
    "ClusterId": "clusterB",
    "Match": { "Path": "/serviceB/{**catch-all}" }
  }
},
    "Clusters": {
      "clusterA": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5263/"
          }
        }
      },
      "clusterB": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5263/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
